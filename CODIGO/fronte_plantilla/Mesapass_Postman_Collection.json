{
  "info": {
    "name": "Mesapass API - Authentication Endpoints",
    "description": "Colección de Postman para probar los endpoints de autenticación de Mesapass - PostgreSQL: mesa_db, puerto 5434, localhost",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    console.log('User registered successfully:', jsonData);",
              "    tests['Status code is 200'] = responseCode.code === 200;",
              "    tests['Response contains id'] = jsonData.hasOwnProperty('id');",
              "    tests['Response contains email'] = jsonData.hasOwnProperty('email');",
              "    tests['Response contains role'] = jsonData.hasOwnProperty('role');",
              "} else if (pm.response.code === 400) {",
              "    var error = pm.response.json();",
              "    tests['Email already registered'] = error.detail.includes('Email already registered');",
              "} else {",
              "    tests['Unexpected status: ' + pm.response.code] = false;",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Test@12345\",\n  \"first_name\": \"Test\",\n  \"last_name\": \"User\",\n  \"full_name\": \"Test User\",\n  \"role\": \"employee\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/register",
          "protocol": "http",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Login User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    pm.environment.set('access_token', jsonData.access_token);",
              "    pm.environment.set('refresh_token', jsonData.refresh_token);",
              "    console.log('Tokens saved to environment');",
              "    tests['Status code is 200'] = true;",
              "    tests['Access token received'] = jsonData.hasOwnProperty('access_token');",
              "    tests['Refresh token received'] = jsonData.hasOwnProperty('refresh_token');",
              "    tests['Token type is bearer'] = jsonData.token_type === 'bearer';",
              "} else {",
              "    var error = pm.response.json();",
              "    tests['Login failed: ' + error.detail] = false;",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Test@12345\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "protocol": "http",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Current User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    tests['Status code is 200'] = true;",
              "    tests['Response contains user data'] = jsonData.hasOwnProperty('id') && jsonData.hasOwnProperty('email');",
              "    console.log('Current user:', jsonData);",
              "} else {",
              "    tests['Authorization failed'] = false;",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/auth/me",
          "protocol": "http",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "me"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Refresh Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    pm.environment.set('access_token', jsonData.access_token);",
              "    tests['Token refreshed successfully'] = true;",
              "    tests['New access token received'] = jsonData.hasOwnProperty('access_token');",
              "} else {",
              "    tests['Refresh token failed'] = false;",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/refresh",
          "protocol": "http",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "refresh"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get All Users (Admin Only)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    tests['Status code is 200'] = true;",
              "    tests['Response is array'] = Array.isArray(jsonData);",
              "    console.log('Total users:', jsonData.length);",
              "} else if (pm.response.code === 403) {",
              "    tests['Permission denied - not admin'] = true;",
              "} else {",
              "    tests['Get users failed: ' + pm.response.code] = false;",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/auth/users",
          "protocol": "http",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Register Admin User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    pm.environment.set('admin_id', jsonData.id);",
              "    console.log('Admin user registered with ID:', jsonData.id);",
              "    tests['Admin user created'] = jsonData.role === 'admin';",
              "} else {",
              "    console.log('Admin registration response:', pm.response.json());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin@12345\",\n  \"first_name\": \"Admin\",\n  \"last_name\": \"User\",\n  \"full_name\": \"Admin User\",\n  \"role\": \"admin\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/register",
          "protocol": "http",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Delete User (Admin Only)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    tests['User deleted successfully'] = true;",
              "    console.log(pm.response.json().message);",
              "} else if (pm.response.code === 404) {",
              "    tests['User not found'] = false;",
              "} else if (pm.response.code === 403) {",
              "    tests['Permission denied - must be admin'] = false;",
              "} else {",
              "    tests['Delete failed: ' + pm.response.code] = false;",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/auth/users/2",
          "protocol": "http",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "users",
            "2"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "protocol": "http",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "response": []
    }
  ],
