{
  "info": {
    "name": "mesapass_postman_test",
    "description": "Colección completa de Postman para MesaPass con soporte multi-tenant. URLs directas a http://localhost:8000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "tenant_id",
      "value": ""
    },
    {
      "key": "user_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData = pm.response.json();",
                  "let user = jsonData.data.data[0];",
                  "",
                  "pm.environment.set(\"access_token\", user.access_token);",
                  "pm.environment.set(\"refresh_token\", user.refresh_token);",
                  "",
                  "if (user.tenants && user.tenants.length > 0) {",
                  "    pm.environment.set(\"tenant_id\", user.tenants[0].tenant_id);",
                  "}",
                  "",
                  "pm.test(\"Login correcto\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Token existe\", function () {",
                  "    pm.expect(pm.environment.get(\"access_token\")).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin@12345\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
