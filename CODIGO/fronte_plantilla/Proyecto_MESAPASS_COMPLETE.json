      "name": "INFORMACIÓN IMPORTANTE",
      "item": [
        {
          "name": "📋 Duración de Tokens",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/docs",
              "host": ["{{base_url}}"],
              "path": ["docs"]
            },
            "description": "⏱️ ACCESS TOKEN: 30 minutos\n⏱️ REFRESH TOKEN: 7 días\n⏱️ PASSWORD RESET CODE: 15 minutos\n⏱️ INVITATION CODE: Sin expiración (única vez)\n\nRUC: Exactamente 13 dígitos, no puede estar registrado\nPASSWORD: Mínimo 6 caracteres\nINVITATION: La contraseña se genera automáticamente (16 caracteres)"
          }
        }
      ]
