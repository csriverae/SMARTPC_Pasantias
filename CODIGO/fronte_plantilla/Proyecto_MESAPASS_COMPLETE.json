{
  "info": {
    "name": "🍽️ MesaPass - SaaS Meal Management System",
    "description": "Colección completa de Postman para pruebas del backend FastAPI SaaS de MesaPass.\n\n⏱️ DURACIONES:\n• Access Token: 30 minutos\n• Refresh Token: 7 días\n• Password Reset Code: 15 minutos\n• Invitation Code: Sin expiración (única vez)\n\n📋 VALIDACIONES:\n• RUC: Exactamente 13 dígitos\n• Contraseña mínimo: 6 caracteres\n• Contraseña auto-generada (invitaciones): 16 caracteres\n\n🔐 SEGURIDAD:\n• Incluir header 'Authorization: Bearer {{token}}'\n• Incluir header 'X-Tenant-ID: {{tenant_id}}' para rutas autenticadas\n• Los endpoints Debug solo están disponibles en desarrollo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "tenant_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "company_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "restaurant_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "employee_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "qr_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "agreement_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "invitation_code",
      "value": "",
      "type": "string"
    },
    {
      "key": "reset_code",
      "value": "",
      "type": "string"
    },
    {
      "key": "invited_user_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "📚 DOCUMENTACIÓN Y DEBUG",
      "item": [
        {
          "name": "📖 Ver Documentación OpenAPI",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/docs",
              "host": ["{{base_url}}"],
              "path": ["docs"]
            },
            "description": "Abre la documentación interactiva de Swagger UI en el navegador"
          }
        },
        {
          "name": "🔍 DEBUG - Ver códigos de recuperación activos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/debug/password-reset-codes",
              "host": ["{{base_url}}"],
              "path": ["auth", "debug", "password-reset-codes"]
            },
            "description": "⚠️ SOLO DESARROLLO - Retorna todos los códigos de recuperación de contraseña activos"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('Retorna array de códigos', function () {",
                  "  pm.expect(data.data.data).to.be.an('array');",
                  "});",
                  "if (data.data.data.length > 0) {",
                  "  pm.test('Primer código tiene estructura correcta', function () {",
                  "    pm.expect(data.data.data[0]).to.have.keys('email', 'reset_code', 'expires_at', 'created_at', 'user_id');",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "🔐 AUTENTICACIÓN",
      "item": [
        {
          "name": "1️⃣ Registrar - Crear Empresa y Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@mesapass.com\",\n  \"password\": \"Admin123\",\n  \"tenant_name\": \"MesaPass Corp\",\n  \"full_name\": \"Admin Usuario\",\n  \"phone\": \"+593987654321\",\n  \"address\": \"Calle Principal 123, Quito\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "description": "Crea un nuevo tenant/empresa y un usuario admin como propietario"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 o 201', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('Retorna access_token', function () {",
                  "  pm.expect(data.data.data.access_token).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('Incluye tenant_id', function () {",
                  "  pm.expect(data.data.data.tenant_id).to.exist;",
                  "});",
                  "if (data.data.data.access_token) {",
                  "  pm.environment.set('token', data.data.data.access_token);",
                  "  pm.environment.set('tenant_id', data.data.data.tenant_id);",
                  "  pm.environment.set('user_id', data.data.data.user.user_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "2️⃣ Login - Por Email y Contraseña",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@mesapass.com\",\n  \"password\": \"Admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Autentica un usuario existente y retorna tokens"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('Retorna tokens', function () {",
                  "  pm.expect(data.data.data.access_token).to.be.a('string');",
                  "  pm.expect(data.data.data.refresh_token).to.be.a('string');",
                  "  pm.expect(data.data.data.token_type).to.equal('bearer');",
                  "});",
                  "if (data.data.data.access_token) {",
                  "  pm.environment.set('token', data.data.data.access_token);",
                  "  pm.environment.set('tenant_id', data.data.data.tenant_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "3️⃣ Obtener Usuario Actual",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{tenant_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            },
            "description": "Obtiene los datos del usuario autenticado actual"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('Retorna datos del usuario', function () {",
                  "  pm.expect(data.data.data).to.have.keys('user_id', 'email', 'full_name', 'phone', 'address', 'role', 'tenant_id', 'tenants');",
                  "});",
                  "pm.test('Usuario tiene phone y address', function () {",
                  "  pm.expect(data.data.data.phone).to.exist;",
                  "  pm.expect(data.data.data.address).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "4️⃣ Olvidé Contraseña - Solicitar Código",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@mesapass.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/forgot-password",
              "host": ["{{base_url}}"],
              "path": ["auth", "forgot-password"]
            },
            "description": "Solicita un código de recuperación (válido 15 minutos) - En desarrollo se retorna en la respuesta"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('Retorna código en desarrollo', function () {",
                  "  pm.expect(data.data.data.reset_code).to.be.a('string').and.not.empty;",
                  "});",
                  "if (data.data.data.reset_code) {",
                  "  pm.environment.set('reset_code', data.data.data.reset_code);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "5️⃣ Reestablecer Contraseña - Con Código",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@mesapass.com\",\n  \"reset_code\": \"{{reset_code}}\",\n  \"new_password\": \"NuevaContraseña123\",\n  \"confirm_password\": \"NuevaContraseña123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/reset-password",
              "host": ["{{base_url}}"],
              "path": ["auth", "reset-password"]
            },
            "description": "Cambia la contraseña usando un código de recuperación válido"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('Mensaje de éxito', function () {",
                  "  pm.expect(data.data.message).to.include('exitosamente');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "6️⃣ Eliminar Usuario",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{tenant_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["auth", "users", "{{user_id}}"]
            },
            "description": "Elimina un usuario del tenant desde el módulo de auth. Solo administradores pueden eliminar usuarios. Usa {{user_id}} para eliminar cualquier usuario del tenant"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK o 204 No Content', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
                  "});",
                  "const data = pm.response.json();",
                  "if (data && data.data && data.data.message) {",
                  "  pm.test('Mensaje de eliminación exitosa', function () {",
                  "    pm.expect(data.data.message).to.include('eliminado');",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
