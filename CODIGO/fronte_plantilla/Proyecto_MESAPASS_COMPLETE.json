{
  "info": {
    "name": "Proyecto_MESAPASS_COMPLETE",
    "description": "Colección Postman para probar el backend FastAPI SaaS multi-tenant de MesaPass.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"123456\",\n  \"tenant_name\": \"Empresa Test\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test('Register status is 200 or 201', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  pm.environment.set('token', data.data.data.access_token);",
                  "  pm.environment.set('tenant_id', data.data.data.tenant_id);",
                  "}",
                  "pm.test('Register returned access_token', function () {",
                  "  pm.expect(data.data.data.access_token).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"123456\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test('Login status is 200 or 201', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  pm.environment.set('token', data.data.data.access_token);",
                  "  if (Array.isArray(data.data.data.tenants) && data.data.data.tenants.length > 0) {",
                  "    pm.environment.set('tenant_id', data.data.data.tenants[0].tenant_id);",
                  "  }",
                  "}",
                  "pm.test('Login returned access_token', function () {",
                  "  pm.expect(data.data.data.access_token).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{tenant_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
