{
  "info": {
    "name": "Proyecto_MESAPASS_COMPLETE",
    "description": "Colección Postman completa para pruebas del backend FastAPI SaaS de MesaPass.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"123456\",\n  \"tenant_name\": \"Empresa Test\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test('Register status is 200 or 201', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  pm.environment.set('token', data.data.data.access_token);",
                  "  pm.environment.set('tenant_id', data.data.data.tenant_id);",
                  "}",
                  "pm.test('Register returned access_token', function () {",
                  "  pm.expect(data.data.data.access_token).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"123456\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test('Login status is 200 or 201', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  pm.environment.set('token', data.data.data.access_token);",
                  "  pm.environment.set('tenant_id', data.data.data.tenant_id);",
                  "}",
                  "pm.test('Login returned access_token', function () {",
                  "  pm.expect(data.data.data.access_token).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-ID", "value": "{{tenant_id}}" }
            ],
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test('Get Current User status is 200', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  pm.environment.set('user_id', data.data.data.user_id);",
                  "}",
                  "pm.test('Current user email is present', function () {",
                  "  pm.expect(data.data.data.email).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-ID", "value": "{{tenant_id}}" }
            ],
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"] }
          }
        },
        {
          "name": "Invite User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-ID", "value": "{{tenant_id}}" }
            ],
            "url": { "raw": "{{base_url}}/api/users/invite", "host": ["{{base_url}}"], "path": ["api", "users", "invite"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"invitado@test.com\",\n  \"role\": \"user\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test('Invite User status is 201', function () {",
                  "  pm.expect(pm.response.code).to.equal(201);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  if (data.data && data.data.data && data.data.data.code) {",
                  "    pm.environment.set('invitation_code', data.data.data.code);",
                  "  }",
                  "}",
                  "pm.test('Invitation code exists', function () {",
                  "  pm.expect(data.data.data.code).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Accept Invitation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/invitations/accept", "host": ["{{base_url}}"], "path": ["api", "invitations", "accept"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{invitation_code}}\",\n  \"password\": \"Invitado123\",\n  \"full_name\": \"Usuario Invitado\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test('Accept Invitation status is 200', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  if (data.data && data.data.data && data.data.data.user_id) {",
                  "    pm.environment.set('invited_user_id', data.data.data.user_id);",
                  "  }",
                  "}",
                  "pm.test('Invitation accepted successfully', function () {",
                  "  pm.expect(data.data.data).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update User Role",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-ID", "value": "{{tenant_id}}" }
            ],
            "url": { "raw": "{{base_url}}/api/users/{{user_id}}/role", "host": ["{{base_url}}"], "path": ["api", "users", "{{user_id}}", "role"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Tenant-ID", "value": "{{tenant_id}}" }
            ],
            "url": { "raw": "{{base_url}}/api/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["api", "users", "{{user_id}}"] }
          }
        }
      ]
    },
