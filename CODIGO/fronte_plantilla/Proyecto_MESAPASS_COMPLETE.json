    {
      "name": "1. Autenticación",
      "item": [
        {
          "name": "Register - Admin (Email, Contraseña, Empresa)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@mesapass.com\",\n  \"password\": \"Admin123\",\n  \"tenant_name\": \"MesaPass Corp\",\n  \"full_name\": \"Admin User\",\n  \"phone\": \"+593987654321\",\n  \"address\": \"Calle Principal 123, Quito\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test('Register status is 200 o 201', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  pm.environment.set('token', data.data.data.access_token);",
                  "  pm.environment.set('tenant_id', data.data.data.tenant_id);",
                  "}",
                  "pm.test('Debe retornar access_token', function () {",
                  "  pm.expect(data.data.data.access_token).to.be.a('string');",
                  "});",
                  "pm.test('Debe incluir phone y address', function () {",
                  "  pm.expect(data.data.data.phone).to.exist;",
                  "  pm.expect(data.data.data.address).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login - Admin (Por Email y Rol)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
