              "raw": "{\n  \"email\": \"newuser@company.com\",\n  \"password\": \"SecurePassword123\",\n  \"tenant_id\": \"67648dc8-e4b8-4d15-ac4f-37574903c9af\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"full_name\": \"John Doe\"\n}"
