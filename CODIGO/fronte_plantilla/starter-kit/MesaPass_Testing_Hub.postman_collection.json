            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pizza Paradise\",\n  \"description\": \"Pizzería de fuego lento\",\n  \"address\": \"Calle Principal 123, Ciudad\",\n  \"phone\": \"+34-912345678\",\n  \"email\": \"contact@pizzaparadise.com\"\n}"
