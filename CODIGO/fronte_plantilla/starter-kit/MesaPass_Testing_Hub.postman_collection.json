              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('user1_token', jsonData.data.access_token);",
                  "    console.log('✅ Token guardado para User 1');",
                  "}"
