{
  "info": {
    "_postman_id": "mesapass-users-complete",
    "name": "MesaPass - Users (Admin & Employee)",
    "description": "Colección completa para gestionar usuarios con roles admin y employee en multi-tenant",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "2.0.0"
  },
  "item": [
    {
      "name": "🔐 AUTH",
      "description": "Autenticación y registro de usuarios",
      "item": [
        {
          "name": "1️⃣  REGISTER - Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@kfc.com\",\n  \"password\": \"123456789\",\n  \"first_name\": \"Carlos\",\n  \"last_name\": \"Rivera\",\n  \"role\": \"admin\",\n  \"tenant_id\": \"96261def-bc6b-422a-9592-edaaa1874662\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/auth/register",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["auth", "register"]
            },
            "description": "Registra un usuario admin en el tenant Default Company"
          },
          "response": []
        },
        {
          "name": "2️⃣  REGISTER - Employee",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"empleado@kfc.com\",\n  \"password\": \"123456789\",\n  \"first_name\": \"Juan\",\n  \"last_name\": \"Pérez\",\n  \"role\": \"employee\",\n  \"tenant_id\": \"96261def-bc6b-422a-9592-edaaa1874662\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/auth/register",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["auth", "register"]
            },
            "description": "Registra un usuario employee en el tenant Default Company"
          },
          "response": []
        },
        {
          "name": "3️⃣  LOGIN - Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@kfc.com\",\n  \"password\": \"123456789\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/auth/login",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["auth", "login"]
            },
            "description": "Login como admin. Copia el access_token para usar en otros endpoints"
          },
          "response": []
        },
        {
          "name": "4️⃣  LOGIN - Employee",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"empleado@kfc.com\",\n  \"password\": \"123456789\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/auth/login",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["auth", "login"]
            },
            "description": "Login como employee"
          },
          "response": []
        },
        {
          "name": "5️⃣  REFRESH TOKEN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"PASTE_REFRESH_TOKEN_HERE\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/auth/refresh",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["auth", "refresh"]
            },
            "description": "Renueva el access token usando el refresh token"
          },
          "response": []
        }
      ]
    },
    {
      "name": "👤 PROFILE",
      "description": "Gestión del perfil del usuario autenticado",
      "item": [
        {
          "name": "6️⃣  GET - Mi Perfil",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer PASTE_ACCESS_TOKEN_HERE",
                "description": "Pega el access_token obtenido del login"
              }
            ],
            "url": {
              "raw": "http://127.0.0.1:8000/auth/me",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["auth", "me"]
            },
            "description": "Obtiene los datos del usuario autenticado"
          },
          "response": []
        },
        {
          "name": "7️⃣  PATCH - Actualizar Perfil",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer PASTE_ACCESS_TOKEN_HERE"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Carlos Andrés\",\n  \"last_name\": \"Rivera García\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/auth/me",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["auth", "me"]
            },
            "description": "Actualiza datos personales del usuario (primera sesión, apellido, etc)"
          },
          "response": []
        },
        {
          "name": "8️⃣  POST - Cambiar Contraseña",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer PASTE_ACCESS_TOKEN_HERE"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"123456789\",\n  \"new_password\": \"NewPassword123!\",\n  \"confirm_password\": \"NewPassword123!\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/auth/me/change-password",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["auth", "me", "change-password"]
            },
            "description": "Cambia la contraseña del usuario autenticado"
          },
          "response": []
        },
        {
          "name": "9️⃣  DELETE - Eliminar Mi Cuenta",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer PASTE_ACCESS_TOKEN_HERE"
              }
            ],
            "url": {
              "raw": "http://127.0.0.1:8000/auth/me",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["auth", "me"]
            },
            "description": "Elimina la cuenta del usuario autenticado (irreversible)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "👥 USERS (ADMIN ONLY)",
      "description": "Gestión de usuarios del tenant (solo admin puede acceder)",
      "item": [
        {
          "name": "🔟 GET - Listar Todos los Usuarios",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer PASTE_ADMIN_TOKEN_HERE",
                "description": "Usa token de un usuario admin"
              }
            ],
            "url": {
              "raw": "http://127.0.0.1:8000/auth/users?skip=0&limit=100&role=",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["auth", "users"],
              "query": [
                {
                  "key": "skip",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "100"
                },
                {
                  "key": "role",
                  "value": "",
                  "description": "Opcional: 'admin' o 'employee' para filtrar"
                }
              ]
            },
            "description": "Lista todos los usuarios del tenant del admin autenticado. Solo admin puede hacerlo"
          },
          "response": []
        },
        {
          "name": "1️⃣1️⃣ GET - Obtener Usuario por ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer PASTE_ADMIN_TOKEN_HERE"
              }
            ],
            "url": {
              "raw": "http://127.0.0.1:8000/auth/users/USER_ID_UUID_HERE",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["auth", "users", "USER_ID_UUID_HERE"]
            },
            "description": "Obtiene un usuario específico por su UUID. Reemplaza USER_ID_UUID_HERE con el ID del usuario"
          },
          "response": []
        },
        {
          "name": "1️⃣2️⃣ PATCH - Actualizar Usuario (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer PASTE_ADMIN_TOKEN_HERE"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Juan Carlos\",\n  \"last_name\": \"Pérez García\",\n  \"role\": \"admin\",\n  \"is_active\": true\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/auth/users/USER_ID_UUID_HERE",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["auth", "users", "USER_ID_UUID_HERE"]
            },
            "description": "Actualiza datos de un usuario. El admin puede cambiar el role o desactivar el usuario"
          },
          "response": []
        },
        {
          "name": "1️⃣3️⃣ DELETE - Eliminar Usuario (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer PASTE_ADMIN_TOKEN_HERE"
              }
            ],
            "url": {
              "raw": "http://127.0.0.1:8000/auth/users/USER_ID_UUID_HERE",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["auth", "users", "USER_ID_UUID_HERE"]
            },
            "description": "Elimina un usuario del tenant. Solo admin puede hacerlo"
          },
          "response": []
        }
      ]
    }
  ]
}
